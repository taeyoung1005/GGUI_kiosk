# ============================================================
# 음성 적응형 키오스크 — 전 모듈 환경변수 모음 (.env.example)
# ------------------------------------------------------------
# 사용법: 이 파일을 .env 로 복사 후 값을 채운다.  cp .env.example .env
# 각 모듈은 자기 디렉토리에 .env 를 두거나, 루트 .env 를 공유할 수 있다.
# mock 모드(키 없이 실행)면 VITE_USE_MOCK=true / MOCK_MODE=1 로 둔다.
# ============================================================

# ── 공통 / mock 토글 ───────────────────────────────────────
# 1 이면 외부 의존성(키·모델·네트워크) 없이 고정 JSON(mock)으로 동작
MOCK_MODE=1

# ── Module C — GGUI 생성 (OpenAI BYOK) ─────────────────────
# GGUI는 OAuth 미지원 → raw API 키 필요. GGUI 생성 LLM(두뇌+렌더)에 사용.
OPENAI_API_KEY=sk-your-openai-key-here
# GGUI 기본 OpenAI 라우트 모델 (Responses API)
GGUI_MODEL=openai:gpt-5.5-2026-04-23
# GGUI MCP+뷰어 포트 (npx @ggui-ai/cli serve 기본값)
GGUI_PORT=6781

# ── Module A — AI 추론 서비스 ──────────────────────────────
# 이식된 나이 모델 폴더 (save_pretrained 결과). 로컬 추론 시 from_pretrained(이 경로)
AGE_MODEL_PATH=./module-a/models/age_model
# STT 모델 — faster-whisper(CPU int8) 또는 mlx-whisper(Apple Silicon)
# 예: large-v3 / medium / small  (Mac은 mlx-community/whisper-large-v3 등)
STT_MODEL=large-v3
# Module A /analyze 인증용 (원격 폴백 노출 시). mock/로컬은 비워도 됨.
ANALYZE_API_KEY=
# Module A 추론 디바이스: cpu | cuda | mps(Apple Silicon)
ANALYZE_DEVICE=cpu
# Module A 서버 포트
ANALYZE_PORT=8000

# ── Module B — 메뉴/주문 백엔드 ────────────────────────────
MENU_PORT=8001
# 시드 메뉴 데이터 경로
MENU_SEED_PATH=./module-b/data/menu.seed.json

# ── Module D — 웹 프론트 (Vite, VITE_ 접두사 = 브라우저 노출) ─
# 1 이면 A/B/C 호출을 mock(고정 JSON)으로 대체 → 백엔드 없이 UI 개발
VITE_USE_MOCK=true
# 각 모듈 엔드포인트. 원격 추론 시 VITE_ANALYZE_URL 만 교체.
VITE_ANALYZE_URL=http://localhost:8000
VITE_MENU_URL=http://localhost:8001
VITE_GGUI_URL=http://localhost:8002
# 프론트 dev 서버 포트(Vite 기본 5173)
VITE_PORT=5173
