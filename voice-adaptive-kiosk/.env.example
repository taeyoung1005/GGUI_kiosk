# ============================================================
# 음성 적응형 키오스크 — 전 모듈 환경변수 모음 (.env.example)
# ------------------------------------------------------------
# 사용법: 이 파일을 .env 로 복사 후 값을 채운다.  cp .env.example .env
# 각 모듈은 자기 디렉토리에 .env 를 두거나, 루트 .env 를 공유할 수 있다.
# mock 모드(키 없이 실행)면 VITE_USE_MOCK=true / MOCK_MODE=1 로 둔다.
# ============================================================

# ── 공통 / mock 토글 ───────────────────────────────────────
# 1 이면 외부 의존성(키·모델·네트워크) 없이 고정 JSON(mock)으로 동작
MOCK_MODE=1

# ── Module C — 적응 UI 생성 ────────────────────────────────
# 실시간 키오스크 데모 기본은 LOCAL 렌더(GGUI_MODE=local)이다.
# GGUI live generation은 offline/prewarm 실험용으로만 사용한다.
GGUI_MODE=local
# GGUI 생성과 Module A 한국어 주문→영어 proxy 번역에 사용.
OPENAI_API_KEY=sk-your-openai-key-here
# GGUI 기본 OpenAI 라우트 모델 (Responses API)
GGUI_MODEL=openai:gpt-5.5-2026-04-23
# Module A 주문 번역 모델 (Responses API)
ORDER_TRANSLATION_MODEL=gpt-4.1-mini
# offline/prewarm 실험에서 blueprint cache를 우회하고 cold generation 강제
GGUI_FORCE_CREATE=0
# GGUI MCP+뷰어 포트 (npx @ggui-ai/cli serve 기본값). GGUI_MODE=ggui일 때만 필요.
GGUI_PORT=6781

# ── Module A — AI 추론 서비스 ──────────────────────────────
# 나이 신호는 public pretrained WavLM provider를 사용한다.
AGE_MODEL_PROVIDER=wavlm_age_sex
AGE_DEVICE=
# STT 모델 — 기본은 OpenAI Audio Transcriptions API(Whisper API).
# 예: whisper-1 / openai:whisper-1 / local:small
STT_MODEL=whisper-1
STT_LANGUAGE=ko
# Module A /analyze 인증용 (원격 폴백 노출 시). mock/로컬은 비워도 됨.
ANALYZE_API_KEY=
# Module A 서버 포트
ANALYZE_PORT=8000
# ElevenLabs 자연스러운 안내 방송 톤 나레이션. 브라우저에는 API key를 노출하지 않고 Module A가 mp3를 생성한다.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_ANNOUNCER_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_ANNOUNCER_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Module A를 브라우저에서 직접 호출할 수 있게 허용할 origin. 로컬 데모는 *로 충분.
CORS_ORIGINS=*

# ── Module B — 메뉴/주문 백엔드 ────────────────────────────
MENU_PORT=8001
# 시드 메뉴 데이터 경로
MENU_SEED_PATH=./module-b/data/menu.seed.json

# ── Module D — 웹 프론트 (Vite, VITE_ 접두사 = 브라우저 노출) ─
# 1 이면 A/B/C 호출을 mock(고정 JSON)으로 대체 → 백엔드 없이 UI 개발
VITE_USE_MOCK=true
# 각 모듈 엔드포인트. 원격 추론 시 VITE_ANALYZE_URL 만 교체.
VITE_ANALYZE_URL=http://localhost:8000
VITE_MENU_URL=http://localhost:8001
VITE_GGUI_URL=http://localhost:8002
# true/1 또는 미설정이면 Module A의 ElevenLabs announcer endpoint를 먼저 시도하고 실패 시 browser TTS로 폴백.
VITE_ELEVENLABS_NARRATION=true
# 프론트 dev 서버 포트(Vite 기본 5173)
VITE_PORT=5173
