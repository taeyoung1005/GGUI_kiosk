# ============================================================
# 음성 적응형 키오스크 — .gitignore (전 모듈 공통)
# ============================================================

# ── 비밀/환경 ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Node / 프론트(D) / GGUI(C) ─────────────────────────────
node_modules/
dist/
build/
.vite/
.cache/
*.tsbuildinfo

# ── 통합 기동 런타임 산출물 (run.sh) ───────────────────────
.run-logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Python / Module A ──────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ── 모델 / 데이터 (대용량, 이식·생성물) ────────────────────
models/
module-a/vendor/
*.safetensors
*.pt
*.bin
*.ckpt
*.onnx
# 오디오 클립/원천(학습 데이터)
data/clips/
module-a/artifacts/
*.wav
*.flac
# imagegen source sheets are reproducible; keep only item SVG assets.
module-b/public/img/menu/_imagegen-contact-sheet*.png
module-d/public/img/menu/_imagegen-contact-sheet*.png
# 단, 시드 메뉴 JSON 은 추적
!module-b/data/menu.seed.json

# ── DB ─────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── OS / 에디터 ────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
