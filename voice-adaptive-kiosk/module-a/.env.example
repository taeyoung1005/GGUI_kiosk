# Module A — AI 추론 서비스 환경변수 예시
# 복사: cp .env.example .env  (그 후 값 수정)
# 기본값(MOCK_MODE=1)으로는 외부 모델/키 없이 즉시 기동된다.

# ── 모드 ──────────────────────────────────────────────────────
# 1 = mock (외부 모델 미사용, 고정 결과)  /  0 = 실모델 추론
MOCK_MODE=1

# ── 서버 ──────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# RELOAD=1                      # 개발 중 자동 리로드 (uvicorn --reload 대용)
# CORS_ORIGINS=*                # 콤마 구분. 운영 시 프론트 도메인만 허용 권장
# API_KEY=                      # 비우면 인증 비활성(로컬). 원격 노출 시 Bearer 토큰 강제

# ── STT (faster-whisper) — MOCK_MODE=0 일 때만 사용 ───────────
STT_MODEL=small               # tiny|base|small|medium|large-v3 또는 로컬 경로
STT_DEVICE=cpu                # cpu | cuda
STT_COMPUTE=int8              # int8 | int8_float16 | float16 | float32
STT_LANGUAGE=ko

# ── 나이 분류 (transformers + torch) — MOCK_MODE=0 ───────────
# 로컬 fine-tuned 모델이 있으면 우선 사용(원격 학습 산출물 이식 경로).
AGE_MODEL_PATH=./models/age_model
# 위 경로가 없으면 아래 허브 모델로 zero-shot.
AGE_HF_MODEL=audeering/wav2vec2-large-robust-24-ft-age-gender
# AGE_DEVICE=                  # 비우면 자동(cuda>mps>cpu)

# ── VAD (silero-vad) — MOCK_MODE=0 ───────────────────────────
VAD_THRESHOLD=0.5             # speech 확률 임계값 (0~1)

# ── 학습 파이프라인 (원격 GPU 전용, training/*.py) ───────────
# AIHUB_ID=                    # AIHub 계정 (다운로드용)
# AIHUB_KEY=
# AIHUB_DATASET_SN=71320       # 연령대별 특징적 발화
# DATA_ROOT=./training/data    # 다운로드·클립 저장 루트
# OUTPUT_DIR=./models/age_model
# BASE_MODEL=facebook/wav2vec2-large-xlsr-53  # 또는 kresnik/wav2vec2-large-xlsr-korean
