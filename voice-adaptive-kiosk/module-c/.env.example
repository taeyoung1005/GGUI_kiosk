# ============================================================
# Module C — GGUI 적응 UI 생성 서비스 (.env.example)
# ------------------------------------------------------------
# 사용법:  cp .env.example .env  후 값 채우기.
# 기본값(local 모드)은 키/외부 의존성 없이 즉시 동작한다 → node server.js
# ============================================================

# 서버 포트 (Module D 의 VITE_GGUI_URL 가 이 포트를 가리킴)
PORT=8002

# 동작 모드:  local | ggui
#   local  → LOCAL_FALLBACK. 키·GGUI 서버 없이 적응형 HTML 직접 생성 (기본, 실데모 메인).
#   ggui   → GGUI MCP 서버의 ggui_push 호출. 아래 OPENAI_API_KEY + GGUI_URL 필요.
#            push가 성공해도 codeReady=false면 LOCAL로 즉시 폴백해 kiosk flow를 막지 않는다.
GGUI_MODE=local

# GGUI 경로(primary)에서만 사용 — GGUI 는 OAuth 미지원 → raw OpenAI API 키 필요.
# GGUI 생성 LLM(두뇌+렌더)에 쓰인다. local 모드면 비워도 됨.
OPENAI_API_KEY=

# GGUI MCP+뷰어 서버 URL (npx @ggui-ai/cli serve 기본 포트 6781).
# ggui_push 호출( {GGUI_URL}/mcp ) + 임베드 뷰어( {GGUI_URL}/r/<shortCode> ) 양쪽에 쓰임.
GGUI_URL=http://localhost:6781

# GGUI MCP 서버 인증 베어러. dev 모드 서버는 비어있지 않은 아무 값이나 'builder' 로 통과.
GGUI_BEARER=dev

# GGUI 생성 모델 (ggui.json#generation.model 과 동일하게 맞춤).
GGUI_MODEL=openai:gpt-5.5-2026-04-23

# GGUI offline/prewarm 실험에서 blueprint cache를 우회하고 cold generation을 강제.
# 실시간 데모 메인(local)에는 영향 없음.
GGUI_FORCE_CREATE=0
