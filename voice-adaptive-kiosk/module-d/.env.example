# ============================================================
# Module D — 웹 키오스크 프론트 (Vite). VITE_ 접두사 = 브라우저 노출.
# 사용법: cp .env.example .env  (mock 모드는 그대로 npm run dev 만으로 동작)
# ============================================================

# 1(=true) 이면 A/B/C 호출을 contracts/mocks 고정 JSON 으로 대체.
# 백엔드/키 없이 일반 UI + 전체 흐름이 화면에서 돈다. (데모 기본값)
VITE_USE_MOCK=true

# ── 실서비스 결선 시 각 모듈 엔드포인트 ─────────────────────
# 원격 추론으로 바꿀 때는 VITE_ANALYZE_URL 만 교체하면 된다.
VITE_ANALYZE_URL=http://localhost:8000
VITE_MENU_URL=http://localhost:8001
# Module C(/generate-ui) 래퍼 서비스. (GGUI MCP 뷰어는 6781, 래퍼는 8002)
VITE_GGUI_URL=http://localhost:8002

# Module A 원격 폴백 노출 시 인증 토큰(Authorization: Bearer ...). mock/로컬은 비움.
VITE_ANALYZE_API_KEY=

# 프론트 dev 서버 포트(Vite 기본 5173)
VITE_PORT=5173
